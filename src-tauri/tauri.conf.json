{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nailbite",
  "version": "0.1.0",
  "identifier": "com.nailbite.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Nailbite - BFRB Detection",
        "label": "main",
        "width": 1024,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "skipTaskbar": false,
        "visible": true,
        "focus": true,
        "decorations": false,
        "transparent": false,
        "shadow": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false
    },
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; media-src 'self' blob:; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "Utility",
    "shortDescription": "BFRB detection and decoupling exercise system",
    "longDescription": "A desktop application that uses webcam-based machine learning to detect body-focused repetitive behaviors (BFRBs) like nail biting and guides users through evidence-based decoupling exercises.",
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
