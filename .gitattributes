# Ensure consistent line endings
*.rs text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.nix text eol=lf
Dockerfile text eol=lf

# Binary files
*.onnx binary filter=lfs diff=lfs merge=lfs -text
*.png binary
*.jpg binary
*.jpeg binary
*.wav binary
*.mp3 binary

# Lock files
Cargo.lock text eol=lf -diff
